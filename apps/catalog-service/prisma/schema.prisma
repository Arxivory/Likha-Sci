generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}
        
enum Domain {
    Engineering
    MedTech
    DataScience
}

model Asset {
    id String @id @default(uuid())
    name String
    description String?
    domain Domain
    price Decimal @default("0.0")

    metadata Json

    storagePath String?
    fileName String?
    fileType String?

    ownerId String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}